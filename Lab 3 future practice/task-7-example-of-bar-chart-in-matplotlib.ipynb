   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Sample data\n",
    "categories = ['A', 'B', 'C', 'D']\n",
    "values = [4, 7, 2, 9]\n",
    "\n",
    "# Create bar chart\n",
    "plt.bar(categories, values, color='green')\n",
    "plt.title(\"Example Bar Chart\")\n",
    "plt.xlabel(\"Categories\")\n",
    "plt.ylabel(\"Values\")\n",
    "# plt.grid(True)\n",
    "plt.show()\n"
   ]
  }
